<!-- views/index.ejs -->
<!DOCTYPE html>
<html>
<head>
  <title>Game Management App</title>
</head>
<body>
  <h1>Game Categories</h1>
  <ul>
      <% categories.forEach(category => { %>
        <li><a href="/<%= category.id %>"><%= category.categories_title %></a> <a href="/<%= category.id %>/edit">edit category</a> </li>
      <% }) %>
  </ul>
  <%- include("partials/errors.ejs") %>
  <form action="/createcategory" method="POST">
    <div>Add a category</div>
    <label for="categoryName">Category Name: </label>
    <input type="text" name="categories_title" id="categories_title" required>
    <label for="description">Description: </label>
    <input type="text" name="description" id="description" required>
    <button type="submit">Submit</button>
  </form>

  <a href="/">Back home</a>
</body>
</html>