<!-- views/edit-category.ejs -->
<!DOCTYPE html>
<html>
<head>
  <title>Game Management App</title>
</head>
<body>
  <h1>Edit Category</h1>
  <%- include("partials/errors.ejs") %>
  <form action="/<%= category.id %>/edit" method="POST">
    <label for="categoryName">Category Name: </label>
    <input type="text" name="categories_title" id="categories_title" value="<%= category.categories_title%>" required>
    <label for="description">Description: </label>
    <input type="text" name="description" id="description"  value="<%= category.description%>" required>
    <button type="submit">Submit</button>
  </form>

  <a href="/">Back home</a>
</body>
</html>